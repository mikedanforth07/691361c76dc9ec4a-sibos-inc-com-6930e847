{
  "routes": [
    {
      "route": "/",
      "serve": "/index.html"
    },
    {
      "route": "/careers-page",
      "serve": "/careers-page.html"
    },
    {
      "route": "/contact-page",
      "serve": "/contact-page.html"
    },
    {
      "route": "/sibos-homepage-v2",
      "serve": "/sibos-homepage-v2.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "*.{css,scss,js,png,gif,ico,jpg,jpeg,svg,webp}",
      "*.json"
    ]
  },
  "platform": {
    "apiRuntime": "node:16"
  },
  "globalHeaders": {
    "cache-control": "public, max-age=3600"
  }
}